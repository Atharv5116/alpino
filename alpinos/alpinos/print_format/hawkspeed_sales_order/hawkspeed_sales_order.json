    "doc_type": "Sales Order",
    "docstatus": 0,
    "doctype": "Print Format",
    "font": "Default",
    "html": "<div style=\"border: 1px solid #000; padding: 0;\">\n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <td width=\"33%\" style=\"border-bottom: 1px solid #000; border-right: none;\"><b>Page No. 1 of 1</b></td>\n            <td width=\"34%\" style=\"border-bottom: 1px solid #000; border-left: none; border-right: none;\" class=\"text-center\"><b style=\"font-size: 12px;\">SALES ORDER</b></td>\n            <td width=\"33%\" style=\"border-bottom: 1px solid #000; border-left: none; text-align: right;\" class=\"text-right\">Original Copy</td>\n        </tr>\n    </table>\n    \n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <td width=\"50%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; padding: 5px; vertical-align: top;\">\n                <table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\n                    <tr>\n                        <td width=\"30%\" valign=\"top\">\n                            <img src=\"/files/hawkspeed_logo.png\" style=\"max-width: 100px; max-height: 80px;\" alt=\"Logo\" onerror=\"this.style.display='none'\">\n                        </td>\n                        <td width=\"70%\" valign=\"top\" style=\"padding-left: 5px;\">\n                            <b style=\"font-size: 13px;\">HAWKSPEED SOLUTION LLP</b><br>\n                            715, Avadh Kontina, Near Luthra Circle, VIP<br>\n                            Road, Vesu, Surat, Gujarat, 39007, India.<br>\n                            Mobile Number: +91 9099038659 | Email<br>\n                            Address: info@hawkspeed.in<br>\n                            PAN - AATFH2502B\n                        </td>\n                    </tr>\n                </table>\n            </td>\n            <td width=\"50%\" style=\"border-bottom: 1px solid #000; padding: 0; vertical-align: top;\">\n                <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; height: 100%;\">\n                    <tr>\n                        <td width=\"50%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000;\">\n                            <b>Sale Order Number</b><br>\n                            {{ doc.name }}\n                        </td>\n                        <td width=\"50%\" style=\"border-bottom: 1px solid #000;\">\n                            <b>Sale Order Date</b><br>\n                            {{ frappe.utils.formatdate(doc.transaction_date) }}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td style=\"border-bottom: 1px solid #000; border-right: 1px solid #000;\">\n                            <b>Place of Supply</b><br>\n                            {{ doc.place_of_supply or '' }}\n                        </td>\n                        <td style=\"border-bottom: 1px solid #000;\">\n                            <b>Order Due Date</b><br>\n                            {{ frappe.utils.formatdate(doc.delivery_date) }}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td colspan=\"2\" style=\"border-bottom: none;\">\n                            <b>Reverse Charge</b><br>\n                            {{ doc.reverse_charge or 'No' }}\n                        </td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n\n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <td width=\"50%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; vertical-align: top;\">\n                <b>Billing Details</b><br>\n                <b>{{ doc.customer_name }}</b><br>\n                {% if doc.contact_email %}Email Address: {{ doc.contact_email }}<br>{% endif %}\n                {{ doc.address_display or '' }}\n            </td>\n            <td width=\"50%\" style=\"border-bottom: 1px solid #000; vertical-align: top;\">\n                <b>Shipping Details</b><br>\n                <b>{{ doc.shipping_address_name or doc.customer_name }}</b><br>\n                {% if doc.contact_email %}Email Address: {{ doc.contact_email }}<br>{% endif %}\n                {{ doc.shipping_address_display or doc.address_display or '' }}\n            </td>\n        </tr>\n    </table>\n\n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <th width=\"5%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: center;\">Sr.</th>\n            <th width=\"35%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: left;\">Item Description</th>\n            <th width=\"15%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: center;\">HSN/SAC code</th>\n            <th width=\"8%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: right;\">Qty</th>\n            <th width=\"7%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: center;\">Unit</th>\n            <th width=\"10%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: right;\">Unit Price</th>\n            <th width=\"8%\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: right;\">Disc.</th>\n            <th width=\"12%\" style=\"border-bottom: 1px solid #000; text-align: right;\">Amount (₹)</th>\n        </tr>\n        {% for item in doc.items %}\n        <tr>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: center; vertical-align: top;\">{{ item.idx }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: left; vertical-align: top;\">{{ item.item_name or item.description }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: center; vertical-align: top;\">{{ item.gst_hsn_code or '' }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: right; vertical-align: top;\">{{ \"{:,.2f}\".format(item.qty) }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: center; vertical-align: top;\">{{ item.uom }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: right; vertical-align: top;\">{{ \"{:,.2f}\".format(item.rate) }}</td>\n            <td style=\"border-bottom: none; border-top: none; border-right: 1px solid #000; text-align: right; vertical-align: top;\">{{ \"{:,.2f}\".format(item.discount_percentage) }} (%)</td>\n            <td style=\"border-bottom: none; border-top: none; text-align: right; vertical-align: top;\">{{ \"{:,.2f}\".format(item.amount) }}</td>\n        </tr>\n        {% endfor %}\n        <tr>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000; padding: 150px 0 0 0;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none; border-right: 1px solid #000;\"></td>\n            <td style=\"border-bottom: 1px solid #000; border-top: none;\"></td>\n        </tr>\n        <tr>\n            <td colspan=\"7\" style=\"border-bottom: 1px solid #000; border-right: 1px solid #000; text-align: center;\"><b>Total</b></td>\n            <td style=\"border-bottom: 1px solid #000; text-align: right;\"><b>{{ \"{:,.2f}\".format(doc.base_grand_total or doc.grand_total) }}</b></td>\n        </tr>\n        <tr>\n            <td colspan=\"8\" style=\"border-bottom: 1px solid #000; text-align: left;\"><b>Rs. {{ doc.in_words or frappe.utils.money_in_words(doc.base_grand_total or doc.grand_total, doc.currency) }}</b></td>\n        </tr>\n    </table>\n\n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <td width=\"20%\"><b>Bank</b></td>\n            <td width=\"80%\">: The Kalupur Commercial Co.Op.</td>\n        </tr>\n        <tr>\n            <td><b>Account Number</b></td>\n            <td>: 04020104458</td>\n        </tr>\n        <tr>\n            <td><b>IFSC</b></td>\n            <td>: KCCB0UDN040</td>\n        </tr>\n        <tr>\n            <td><b>Branch</b></td>\n            <td>: UDHANA-UDYOGNAGAR</td>\n        </tr>\n        <tr>\n            <td style=\"border-bottom: 1px solid #000;\"><b>Name</b></td>\n            <td style=\"border-bottom: 1px solid #000;\">: HAWKSPEED SOLUTION LLP</td>\n        </tr>\n    </table>\n\n    <table width=\"100%\" cellspacing=\"0\" cellpadding=\"4\" style=\"border-collapse: collapse; font-family: sans-serif; font-size: 11px;\">\n        <tr>\n            <td>\n                <b>Terms and Conditions:</b><br>\n                E & O.E<br>\n                1. Goods once sold will not be taken back.<br>\n                2. Interest @ 18% p.a. will be charged if the payment for HAWKSPEED Solution LLP is not made within the stipulated time.<br>\n                3. Subject to 'Gujarat' Jurisdiction only.\n            </td>\n        </tr>\n    </table>\n</div>\n\n<div style=\"text-align: center; margin-top: 5px; font-family: sans-serif; font-size: 11px;\">\n    Order Created by <a href=\"http://www.mazu.in\" style=\"color: blue; text-decoration: underline;\">www.mazu.in</a>\n</div>",
